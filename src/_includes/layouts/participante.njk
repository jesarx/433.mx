---
layout: layouts/base.njk
show_location: false
---
<section class="hero-bg min-h-screen pt-32 pb-20">
  <div class="max-w-4xl mx-auto px-6">
    <div class="fade-in visible">

      <a href="/#participantes" class="inline-flex items-center text-gray-600 hover:text-gray-900 mb-12 transition-colors">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        Volver a participantes
      </a>

      <div class="flex flex-col md:flex-row items-center md:items-start gap-12 mb-12">
        <img src="/{{ p.foto }}" alt="{{ p.nombre }}" class="participant-photo-large shadow-lg">
        <div class="text-center md:text-left">
          <h1 class="text-4xl md:text-5xl font-light text-gray-900 mb-4">{{ p.nombre }}</h1>
          {% if p.rol %}<p class="text-xl text-gray-600">{{ p.rol }}</p>{% endif %}
        </div>
      </div>

      <div class="bg-white rounded-xl p-8 md:p-12 shadow-sm">
        <h2 class="text-2xl font-medium text-gray-900 mb-6">Biografía</h2>
        <div class="prose prose-lg text-gray-700 leading-relaxed space-y-4">
          {{ content | safe }}
        </div>
      </div>

    </div>
  </div>
</section>
