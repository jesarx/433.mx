---
layout: layouts/base.njk
show_location: true
---
<section class="hero-bg min-h-screen pt-32 pb-20">
  <div class="max-w-4xl mx-auto px-6">
    <div class="fade-in visible">

      <a href="/" class="inline-flex items-center text-gray-600 hover:text-gray-900 mb-12 transition-colors">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        Volver al inicio
      </a>

      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-light text-gray-900 mb-4">{{ convocatoria_titulo }}</h1>
        <p class="text-xl text-gray-600">Cu4tro Tr3inta y Tr3s</p>
      </div>

      <div class="bg-white rounded-xl p-8 md:p-12 shadow-sm">
        <div class="prose prose-lg text-gray-700 leading-relaxed">
          {{ content | safe }}
        </div>
      </div>

      <div class="mt-12 text-center text-gray-600">
        <p>¿Tienes dudas? Escríbenos a <a href="mailto:{{ site.email }}" class="text-gray-900 hover:underline">{{ site.email }}</a></p>
      </div>

    </div>
  </div>
</section>
