      {% set logos = [
        { src: "2_LOGOTIPO_fuenteaurora_DIGITAL_TRANSP.png", alt: "Fuente Aurora Club Social" },
        { src: "Gobierno de Michoacán_idXveQM4vY_1.svg", alt: "Gobierno de Michoacán" },
        { src: "Logo CCACJP 2023.svg", alt: "CCACJP" },
        { src: "casawerma logo.png", alt: "Casa Werma" },
        { src: "Zictrasobreblanco_3.png", alt: "Zictra Ensamble" },
        { src: "Jacaranda.jpg", alt: "La Jacaranda Cultural" },
        { src: "Orquídea.jpg", alt: "Taller Azul Orquídea" },
        { src: "logo-posada-yolihuani-cuadro gris.jpg", alt: "Hotel Posada Yolihuani" }
      ] %}

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-x-12 gap-y-10 w-full items-center">
        {% for logo in logos %}
        <div class="flex items-center justify-center h-24">
          <img src="/images/logos/{{ logo.src | urlencode }}" alt="{{ logo.alt }}" class="max-h-20 max-w-full w-auto object-contain logo-hover">
        </div>
        {% endfor %}
      </div>

      <div class="w-full flex justify-center pt-8 border-t border-gray-100">
        <img src="/images/logos/SecretariaCultura_Sistema_Creacion_color.png" alt="Secretaría de Cultura — Sistema de Apoyos a la Creación y Proyectos Culturales" class="max-h-16 w-auto object-contain logo-hover">
      </div>

    </div>
  </div>
</div>

<script>
  // Smooth scroll para links del navbar cuando estamos en el index
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function(e) {
      e.preventDefault();
      const target = document.querySelector(this.getAttribute('href'));
      if (target) {
        if (menu) menu.classList.add('hidden');
        target.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });

  // Lightbox
  function openLightbox(img) {
    const lb = document.getElementById('lightbox');
    document.getElementById('lightbox-img').src = img.src;
    document.getElementById('lightbox-img').alt = img.alt;
    lb.classList.remove('hidden');
    lb.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }
  function closeLightbox() {
    const lb = document.getElementById('lightbox');
    lb.classList.add('hidden');
    lb.classList.remove('flex');
    document.body.style.overflow = '';
  }
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });

  // Stagger cards
  document.querySelectorAll('#participantes .group').forEach((card, i) => {
    card.style.transitionDelay = `${i * 100}ms`;
  });
</script>
