---
layout: layouts/base.njk
title: "Espacio para el sonido"
show_location: true
permalink: "/index.html"
---

{# ── HERO ── #}
<section id="inicio" class="hero-bg min-h-screen flex items-center justify-center pt-20 pb-20">
  <div class="mx-auto px-6 text-center">
    <div class="fade-in">
      <img src="/images/433_caracteres1.png" alt="4'33''" class="h-62 w-auto mx-auto mb-8">
      <p class="text-xl md:text-2xl text-gray-600 mb-8 max-w-4xl mx-auto leading-relaxed">
        Del martes 4 al domingo 9 de agosto del 2026<br>
        Pátzcuaro, Michoacán
      </p>
      <div class="text-lg text-gray-700 max-w-4xl mx-auto leading-relaxed">
        <p class="mb-4">Es un espacio de confluencia de una comunidad musical con oídos abiertos al sonido entendido en su amplio espectro.</p>
        <p>Busca generar un encuentro intensivo entre diferentes agentes musicales que permita consolidar una labor dentro de las diversas formas de hacer, escuchar y pensar las músicas de nuestra época, así como de lo que ahora podemos considerar como la música clásica de la última etapa del Siglo XX.</p>
      </div>
    </div>
  </div>
</section>

{# ── FESTIVAL ── #}
<section id="festival" class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <div class="fade-in">
      <h2 class="text-4xl md:text-5xl font-light text-gray-900 mb-12 text-center">Cuatro treinta y tres</h2>
      <div class="prose prose-lg mx-auto text-gray-700 leading-relaxed">
        <p class="text-xl mb-8">
          En una intensa semana se concentran actores musicales del país para gestar una labor colectiva en torno a las músicas clásicas principalmente de mediados del Siglo XX y del Siglo XXI donde habrá conciertos, estrenos de obras comisionadas, conferencias, conversatorios, clases de composición, trabajo con ensamble de estudiantes, ensayos abiertos.
        </p>
        <div class="grid md:grid-cols-2 gap-8 mt-12">
          <div class="space-y-4">
            <h3 class="text-2xl font-medium text-gray-900">Actividades</h3>
            <ul class="space-y-2 text-gray-700">
              <li>• Conciertos</li>
              <li>• Estrenos de obras comisionadas</li>
              <li>• Conferencias</li>
              <li>• Conversatorios</li>
            </ul>
          </div>
          <div class="space-y-4">
            <h3 class="text-2xl font-medium text-gray-900">Formación</h3>
            <ul class="space-y-2 text-gray-700">
              <li>• Clases de composición</li>
              <li>• Trabajo con ensamble de estudiantes</li>
              <li>• Ensayos abiertos</li>
              <li>• Talleres especializados</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{# ── PARTICIPANTES ── #}
<section id="participantes" class="py-20 bg-gray-50">
  <div class="max-w-6xl mx-auto px-6">
    <div class="fade-in">

      {# Macro for participant card #}
      {% macro participanteCard(p) %}
      <a href="/{{ p.slug }}/" class="group bg-white p-6 rounded-lg shadow-sm hover:shadow-md transition-all duration-300">
        <div class="participant-card">
          <img src="/{{ p.foto }}" alt="{{ p.nombre }}" class="participant-photo">
          <div>
            <h3 class="text-xl font-medium text-gray-900 group-hover:text-gray-700 transition-colors">{{ p.nombre }}</h3>
            {% if p.rol %}<p class="text-gray-600 mt-1">{{ p.rol }}</p>{% endif %}
          </div>
        </div>
      </a>
      {% endmacro %}

      <h2 class="text-4xl md:text-5xl font-light text-gray-900 mb-12 text-center">Tutores composición 2026</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {% for p in participantes.tutores_composicion %}
          {{ participanteCard(p) }}
        {% endfor %}
      </div>

      <h2 class="text-4xl md:text-5xl font-light text-gray-900 my-12 text-center">Tutores ensamble de estudiantes 2026</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {% for p in participantes.tutores_ensamble %}
          {{ participanteCard(p) }}
        {% endfor %}
      </div>

      <h2 class="text-4xl md:text-5xl font-light text-gray-900 my-12 text-center">Participantes invitados 2026</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {% for p in participantes.participantes_invitados %}
          {{ participanteCard(p) }}
        {% endfor %}
      </div>

      <h2 class="text-4xl md:text-5xl font-light text-gray-900 my-12 text-center">Compositores comisionados 2026</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {% for p in participantes.compositores_comisionados %}
          {{ participanteCard(p) }}
        {% endfor %}
      </div>

    </div>
  </div>
</section>
{# ── CONCIERTOS ── #}

<section id="conciertos" class="py-20 bg-gray-50">
  <div class="max-w-6xl mx-auto px-6">
    <div class="fade-in visible">
      <h2 class="text-4xl md:text-5xl font-light text-gray-900 mb-12 text-center">Programación conciertos</h2>
      <div class="grid md:grid-cols-4 gap-6">
        {% set conciertos = [
{ src: "images/conciertos/1.jpg" },
{ src: "images/conciertos/2.jpg" },
{ src: "images/conciertos/3.jpg" },
{ src: "images/conciertos/4.jpg" },
{ src: "images/conciertos/5.jpg" },
{ src: "images/conciertos/6.jpg" },
{ src: "images/conciertos/7.jpg" },
{ src: "images/conciertos/8.jpg" }
        ] %}
        {% for c in conciertos %}
        <img src="/{{ c.src }}" alt="{{ c.alt }}" class="w-full rounded-xl shadow-md cursor-pointer hover:opacity-90 transition-opacity" onclick="openLightbox(this)">
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{# ── LIGHTBOX ── #}
<div id="lightbox" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/80 backdrop-blur-sm" onclick="closeLightbox(event)">
  <button onclick="closeLightbox(event)" class="absolute top-6 right-6 text-white hover:text-gray-300 transition-colors z-[101]">
    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
    </svg>
  </button>
  <img id="lightbox-img" src="" alt="" class="max-w-[90vw] max-h-[90vh] rounded-xl shadow-2xl object-contain" onclick="event.stopPropagation()">
</div>

